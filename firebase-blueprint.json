{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "xp": { "type": "integer" },
        "rank": { "type": "string" },
        "totalSolved": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "xp", "rank", "totalSolved", "createdAt"]
    },
    "Score": {
      "title": "Score",
      "description": "A record of a solved puzzle for the leaderboard",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard", "expert"] },
        "timeSeconds": { "type": "integer" },
        "puzzleId": { "type": "string" },
        "solvedAt": { "type": "string", "format": "date-time" },
        "isDaily": { "type": "boolean" }
      },
      "required": ["userId", "displayName", "difficulty", "timeSeconds", "puzzleId", "solvedAt"]
    },
    "DailyPuzzle": {
      "title": "Daily Puzzle",
      "description": "The shared puzzle for a specific day",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "difficulty": { "type": "string" },
        "grid": { "type": "string" },
        "solution": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "difficulty", "grid", "solution", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles and stats"
    },
    "/scores/{scoreId}": {
      "schema": "Score",
      "description": "Stores scores for the global leaderboard"
    },
    "/dailyChallenges/{date}": {
      "schema": "DailyPuzzle",
      "description": "Stores the daily challenge puzzle"
    }
  }
}
