rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users ---
    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 100
        && data.xp is int && data.xp >= 0
        && data.rank is string && data.rank.size() <= 20
        && data.totalSolved is int && data.totalSolved >= 0
        && data.createdAt is string; // Simplified for MVP
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) 
        && isValidUser(request.resource.data)
        && request.resource.data.uid == resource.data.uid;
    }

    // --- Scores ---
    function isValidScore(data) {
      return data.userId == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 100
        && data.difficulty in ['easy', 'medium', 'hard', 'expert']
        && data.timeSeconds is int && data.timeSeconds > 0
        && data.puzzleId is string
        && data.solvedAt is string;
    }

    match /scores/{scoreId} {
      allow read: if true; // Public leaderboard
      allow create: if isSignedIn() && isValidScore(request.resource.data);
      // No updates or deletes for scores to maintain integrity
    }

    // --- Daily Challenges ---
    // Only server-side or admin could create these ideally, 
    // but for this MVP we'll let any signed-in user "seed" it if it doesn't exist,
    // though a cron job or server init is better.
    // We'll restrict to READ for users, and a specific "internal" check or just allow if it matches the format.
    match /dailyChallenges/{date} {
      allow read: if true;
      allow create: if isSignedIn(); // Allow seeding the daily puzzle
    }
  }
}
